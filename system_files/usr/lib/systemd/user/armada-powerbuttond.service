[Unit]
Description=Armada Steam power-button handler
PartOf=gamescope-session-plus@steam.service
StartLimitIntervalSec=0

[Service]
ExecStart=/usr/bin/systemd-inhibit --what=handle-power-key:handle-suspend-key:handle-lid-switch --who=armada-powerbuttond --why="Steam Game Mode handles power events" --mode=block /usr/libexec/armada/powerbuttond
Restart=on-failure
RestartSec=1
RuntimeDirectory=armada-powerbuttond
Environment=ARMADA_POWERBUTTON_PID_FILE=%t/armada-powerbuttond/pid
