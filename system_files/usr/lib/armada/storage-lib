# Resolve the internal data LUN. UFS handhelds expose several LUNs as /dev/sd?
# whose letters aren't stable across boots, so match by a partition label on it
# (userdata = Android, ARMADA_ROOT/ROCKNIX = Armada) and return 1 if none found.
armada_internal_device() {
    local label part parent
    for label in userdata ARMADA_ROOT ROCKNIX; do
        part=$(realpath -e "/dev/disk/by-partlabel/${label}" 2>/dev/null) \
            || part=$(blkid -t "PARTLABEL=${label}" -o device 2>/dev/null | head -1) || true
        [[ -n "${part:-}" ]] || continue
        parent=$(lsblk -no pkname "$part" 2>/dev/null | head -1) || true
        [[ -n "$parent" ]] && { printf '/dev/%s\n' "$parent"; return 0; }
    done
    return 1
}
