#!/usr/bin/bash
# Inhibit (1) or re-enable (0) an input device by name. Used to silence the
# secondary touchscreen while gamescope owns the only visible screen.
set -euo pipefail

name="${1:?usage: touchscreen-inhibit <device-name> <1|0>}"
state="${2:?usage: touchscreen-inhibit <device-name> <1|0>}"

found=0
for dev in /sys/class/input/input*/; do
    [[ "$(cat "${dev}name" 2>/dev/null)" == "${name}" ]] || continue
    found=1
    if ! echo "${state}" > "${dev}inhibited"; then
        systemd-cat -t armada-touchscreen-inhibit -p warning \
            <<<"failed to set ${name} inhibited=${state}" 2>/dev/null || true
        exit 1
    fi
done

if (( ! found )); then
    systemd-cat -t armada-touchscreen-inhibit -p warning \
        <<<"input device not found: ${name}" 2>/dev/null || true
    exit 1
fi
